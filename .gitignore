# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
.next/
out/
dist/
build/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# ─── Environment files ────────────────────────────────────────────────────────
# Local dev envs — safe to ignore
.env
.env.local
.env.development
.env.test

# Production envs — NEVER commit real secrets
.env.production
.env.production.local

# ─── Prisma ───────────────────────────────────────────────────────────────────
# Generated client is rebuilt on deploy
apps/api/node_modules/.prisma/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# TypeScript incremental build cache
*.tsbuildinfo
