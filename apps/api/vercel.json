{
  "framework": "express",
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate --schema prisma/schema.prisma",
  "experimentalServices": {
    "web": {
      "entrypoint": "api/index.mjs",
      "framework": "express",
      "routePrefix": "/"
    }
  },
  "crons": [
    {
      "path": "/jobs/fetch-odds",
      "schedule": "0 0 * * *"
    }
  ]
}
